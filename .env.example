# Porta da API (e do dashboard servido por ela em produção)
PORT=3333

# Conexão com o Redis
REDIS_URL=redis://localhost:6379

# Fonte de status:
#   availability (padrão) = scraping da página oficial de disponibilidade
#     (pública, NÃO exige certificado A1, funciona em qualquer rede)
#   soap = consulta SOAP direta aos webservices (dados mais ricos, exige
#     saída de rede e, em vários autorizadores, certificado A1)
STATUS_SOURCE=availability

# Agendamento das checagens (cron). Padrão: a cada 5 minutos.
CRON_EXPRESSION=*/5 * * * *

# Consulta à SEFAZ (usado quando STATUS_SOURCE=soap)
SEFAZ_TIMEOUT_MS=15000
SEFAZ_CONCURRENCY=5

# Retenção do histórico curto no Redis (ms). Padrão: 72h.
HISTORY_RETENTION_MS=259200000

# Rate limit (requisições por minuto por IP). 0 desativa.
RATE_LIMIT_MAX=120

# Certificado digital A1 (.pfx) para mTLS — exigido por vários autorizadores.
# Sem ele, o handshake TLS falha em alguns estados.
# SEFAZ_CERT_PATH=./certs/empresa.pfx
# SEFAZ_CERT_PASSPHRASE=sua_senha

# Token para endpoints protegidos (disparo manual de checagem). Vazio = aberto.
# ADMIN_TOKEN=

# Porta exposta no host pelo docker-compose
# APP_PORT=3333
# REDIS_PORT=6379
